# =============================================================================
# AI NEWS AGENT — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# -----------------------------------------------------------------------------
# LLM Provider (choose ONE, others can be left blank)
# -----------------------------------------------------------------------------

# Option 1: OpenRouter (free models available)
# Sign up at https://openrouter.ai — free tier includes many models
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Option 2: Groq (very fast, generous free tier)
# Sign up at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Option 3: Google Gemini (free tier)
# Get key at https://aistudio.google.com
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Active provider: openrouter | groq | gemini
LLM_PROVIDER=groq

# -----------------------------------------------------------------------------
# LangSmith Observability (Free Tier)
# Sign up at https://smith.langchain.com
# -----------------------------------------------------------------------------
LANGCHAIN_TRACING_V2=true
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=ai-news-agent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# -----------------------------------------------------------------------------
# Email Configuration
# -----------------------------------------------------------------------------
# Recipient
EMAIL_TO=towhid4635@gmail.com

# Gmail SMTP (recommended — use App Password, not your main password)
# Enable 2FA, then generate App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_gmail@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAIL_FROM=your_gmail@gmail.com
EMAIL_FROM_NAME=AI News Agent

# Outlook SMTP (alternative)
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587

# -----------------------------------------------------------------------------
# Scheduling
# -----------------------------------------------------------------------------
# Cron-style: daily at 06:30 AM
SCHEDULE_HOUR=6
SCHEDULE_MINUTE=30
TIMEZONE=Asia/Dhaka

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=production
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./data/news_agent.db
MAX_ARTICLES_PER_RUN=100
TOP_N_ARTICLES=10
MIN_RELEVANCE_SCORE=40

# API server
API_HOST=0.0.0.0
API_PORT=8000
